---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
---

<Layout title="Docs — Code Addiction">
  <!-- Nav -->
  <nav class="fixed top-0 w-full z-50 backdrop-blur-md bg-surface/80 border-b border-white/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <button id="docs-sidebar-toggle" class="lg:hidden p-1 -ml-1 text-muted-light hover:text-foreground" aria-label="Toggle sidebar">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
        <a href="/" class="font-display font-bold text-foreground tracking-tight text-lg">
          <span class="text-accent">+</span> code addiction
        </a>
      </div>
      <div class="hidden md:flex items-center gap-6">
        <a href="/" class="text-sm text-muted-light hover:text-accent transition-colors">Home</a>
        <a href="#commands" class="text-sm text-muted-light hover:text-accent transition-colors">Commands</a>
        <a href="#flows" class="text-sm text-muted-light hover:text-accent transition-colors">Flows</a>
        <a href="https://github.com/brabos-ai/code-addiction" target="_blank" rel="noopener" class="text-sm text-surface bg-accent hover:bg-accent-dim font-mono font-medium px-4 py-1.5 rounded-md transition-colors">
          GitHub
        </a>
      </div>
      <div class="flex md:hidden items-center">
        <a href="https://github.com/brabos-ai/code-addiction" target="_blank" rel="noopener" class="text-sm text-surface bg-accent hover:bg-accent-dim font-mono font-medium px-3 py-1.5 rounded-md transition-colors">
          GitHub
        </a>
      </div>
    </div>
  </nav>

  <!-- Mobile Backdrop -->
  <div id="docs-backdrop" class="fixed inset-0 bg-black/60 z-40 hidden lg:hidden backdrop-blur-sm transition-opacity"></div>

  <div class="flex pt-14">
    <!-- Sidebar -->
    <aside id="docs-sidebar" class="fixed top-14 left-0 w-64 h-[calc(100vh-3.5rem)] overflow-y-auto border-r border-white/5 bg-surface z-50 px-6 py-8 transform -translate-x-full lg:translate-x-0 transition-transform duration-300 ease-in-out">
      <nav class="space-y-6 text-sm">
        <div class="lg:hidden pb-2 mb-2">
          <a href="/" class="flex items-center gap-2 text-accent hover:text-accent-dim transition-colors font-medium">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
            Back to Home
          </a>
        </div>
        <div>
          <p class="font-mono text-accent text-xs tracking-widest uppercase mb-3">Getting Started</p>
          <ul class="space-y-2">
            <li><a href="#about" class="text-muted-light hover:text-foreground transition-colors">About</a></li>
            <li><a href="#install" class="text-muted-light hover:text-foreground transition-colors">Installation</a></li>
            <li><a href="#quickstart" class="text-muted-light hover:text-foreground transition-colors">Quickstart</a></li>
          </ul>
        </div>
        <div>
          <p class="font-mono text-accent text-xs tracking-widest uppercase mb-3">Reference</p>
          <ul class="space-y-2">
            <li><a href="#commands" class="text-muted-light hover:text-foreground transition-colors">Commands</a></li>
            <li><a href="#flows" class="text-muted-light hover:text-foreground transition-colors">Flows</a></li>
            <li><a href="#scenarios" class="text-muted-light hover:text-foreground transition-colors">Scenarios</a></li>
          </ul>
        </div>
        <div>
          <p class="font-mono text-accent text-xs tracking-widest uppercase mb-3">Deep Dive</p>
          <ul class="space-y-2">
            <li><a href="#skills" class="text-muted-light hover:text-foreground transition-colors">Skills</a></li>
            <li><a href="#features" class="text-muted-light hover:text-foreground transition-colors">Optional Features</a></li>
            <li><a href="#providers" class="text-muted-light hover:text-foreground transition-colors">Providers</a></li>
            <li><a href="#structure" class="text-muted-light hover:text-foreground transition-colors">Project Structure</a></li>
          </ul>
        </div>
      </nav>
    </aside>

    <!-- Main content -->
    <main class="flex-1 lg:ml-64 px-6 sm:px-12 py-12 max-w-4xl">

      <!-- ABOUT -->
      <section id="about" class="mb-20">
        <p class="font-mono text-accent text-xs tracking-widest uppercase mb-4">Getting Started</p>
        <h1 class="font-display font-extrabold text-4xl sm:text-5xl mb-6">
          What is Code<br/><span class="text-accent glow">Addiction</span>?
        </h1>
        <p class="text-muted-light text-lg leading-relaxed mb-6">
          Code Addiction is a spec-driven framework for AI coding assistants.
          It standardizes how features go from idea to production through structured,
          repeatable workflows — installed in any project with a single command.
        </p>
        <div class="grid sm:grid-cols-3 gap-4">
          <div class="p-4 rounded-lg border border-white/5 bg-white/[0.02]">
            <div class="text-accent font-mono text-sm mb-2">.codeadd/</div>
            <p class="text-muted-light text-sm">Shared core: commands, scripts, skills, templates</p>
          </div>
          <div class="p-4 rounded-lg border border-white/5 bg-white/[0.02]">
            <div class="text-accent font-mono text-sm mb-2">Provider adapters</div>
            <p class="text-muted-light text-sm">Claude, Codex, Antigravity, KiloCode, OpenCode</p>
          </div>
          <div class="p-4 rounded-lg border border-white/5 bg-white/[0.02]">
            <div class="text-accent font-mono text-sm mb-2">codeadd CLI</div>
            <p class="text-muted-light text-sm">install, update, uninstall, doctor, validate, features, config</p>
          </div>
        </div>
      </section>

      <!-- INSTALL -->
      <section id="install" class="mb-20">
        <h2 class="font-display font-bold text-2xl sm:text-3xl mb-6">Installation</h2>
        <p class="text-muted-light mb-6">Requires Node.js 18+. Works on Windows, macOS, and Linux.</p>

        <div class="bg-white/[0.03] border border-white/10 rounded-xl p-6 font-mono text-sm space-y-3">
          <div><span class="text-muted select-none"># install in your project</span></div>
          <div><span class="text-accent select-none">$ </span><span class="text-foreground">npx codeadd install</span></div>
          <div class="pt-2"><span class="text-muted select-none"># install specific version</span></div>
          <div><span class="text-accent select-none">$ </span><span class="text-foreground">npx codeadd install --version v2.0.1</span></div>
          <div class="pt-2"><span class="text-muted select-none"># install from a specific branch</span></div>
          <div><span class="text-accent select-none">$ </span><span class="text-foreground">npx codeadd install --branch feature-xyz</span></div>
        </div>

        <h3 class="font-display font-semibold text-lg mt-8 mb-4">What gets installed</h3>
        <div class="bg-white/[0.03] border border-white/10 rounded-xl p-6 font-mono text-sm leading-relaxed">
          <span class="text-muted">your-project/</span><br/>
          <span class="text-accent">├── .codeadd/</span><span class="text-muted ml-6">← core (always)</span><br/>
          <span class="text-foreground">├── .claude/</span><span class="text-muted ml-8">← Claude Code</span><br/>
          <span class="text-foreground">├── .agent/</span><span class="text-muted ml-8">← Codex (OpenAI)</span><br/>
          <span class="text-foreground">├── .agents/</span><span class="text-muted ml-7">← Antigravity</span><br/>
          <span class="text-foreground">├── .kilocode/</span><span class="text-muted ml-4">← KiloCode</span><br/>
          <span class="text-foreground">└── .opencode/</span><span class="text-muted ml-4">← OpenCode</span>
        </div>
      </section>

      <!-- QUICKSTART -->
      <section id="quickstart" class="mb-20">
        <h2 class="font-display font-bold text-2xl sm:text-3xl mb-6">Quickstart</h2>
        <p class="text-muted-light mb-6">After installing, use these CLI commands to manage your setup:</p>

        <div class="space-y-3">
          <div class="flex items-start gap-4 p-4 rounded-lg border border-white/5 bg-white/[0.02]">
            <code class="text-accent font-mono text-sm whitespace-nowrap">npx codeadd doctor</code>
            <span class="text-muted-light text-sm">Check environment health — Node, Git, installation status</span>
          </div>
          <div class="flex items-start gap-4 p-4 rounded-lg border border-white/5 bg-white/[0.02]">
            <code class="text-accent font-mono text-sm whitespace-nowrap">npx codeadd validate</code>
            <span class="text-muted-light text-sm">Validate file integrity via SHA-256 hashes</span>
          </div>
          <div class="flex items-start gap-4 p-4 rounded-lg border border-white/5 bg-white/[0.02]">
            <code class="text-accent font-mono text-sm whitespace-nowrap">npx codeadd validate --repair</code>
            <span class="text-muted-light text-sm">Restore missing or modified files from the release</span>
          </div>
          <div class="flex items-start gap-4 p-4 rounded-lg border border-white/5 bg-white/[0.02]">
            <code class="text-accent font-mono text-sm whitespace-nowrap">npx codeadd update</code>
            <span class="text-muted-light text-sm">Update to latest release, or re-pull current branch</span>
          </div>
          <div class="flex items-start gap-4 p-4 rounded-lg border border-white/5 bg-white/[0.02]">
            <code class="text-accent font-mono text-sm whitespace-nowrap">npx codeadd uninstall</code>
            <span class="text-muted-light text-sm">Clean removal of all Code Addiction files (user files are kept)</span>
          </div>
          <div class="flex items-start gap-4 p-4 rounded-lg border border-white/5 bg-white/[0.02]">
            <code class="text-accent font-mono text-sm whitespace-nowrap">npx codeadd uninstall --force</code>
            <span class="text-muted-light text-sm">Skip confirmation prompt during uninstall</span>
          </div>
          <div class="flex items-start gap-4 p-4 rounded-lg border border-white/5 bg-white/[0.02]">
            <code class="text-accent font-mono text-sm whitespace-nowrap">npx codeadd features</code>
            <span class="text-muted-light text-sm">List, enable, or disable optional features (e.g. TDD, Startup Test)</span>
          </div>
          <div class="flex items-start gap-4 p-4 rounded-lg border border-white/5 bg-white/[0.02]">
            <code class="text-accent font-mono text-sm whitespace-nowrap">npx codeadd config show</code>
            <span class="text-muted-light text-sm">Display installation configuration. Add <code class="text-foreground">--verbose</code> to check for updates</span>
          </div>
        </div>
      </section>

      <!-- Divider -->
      <div class="border-t border-white/5 my-16"></div>

      <!-- COMMANDS -->
      <section id="commands" class="mb-20">
        <p class="font-mono text-accent text-xs tracking-widest uppercase mb-4">Reference</p>
        <h2 class="font-display font-bold text-2xl sm:text-3xl mb-4">Commands</h2>
        <p class="text-muted-light mb-8">
          Every command is a slash command you type in your AI coding assistant.
          They orchestrate discovery, planning, implementation, and delivery.
        </p>

        <!-- Commands Map -->
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4 mb-12">
          <!-- Discovery -->
          <div class="rounded-xl border border-white/5 bg-white/[0.015] p-5">
            <h3 class="font-display font-bold text-xs tracking-widest uppercase text-foreground mb-4">Discovery</h3>
            <div class="space-y-2.5">
              <div class="rounded-lg border border-white/10 bg-white/[0.03] px-4 py-2.5 hover:border-accent/20 transition-colors">
                <code class="text-accent font-mono text-sm">/add.brainstorm</code>
                <p class="text-muted text-xs mt-0.5">Explore ideas (read-only)</p>
              </div>
              <div class="rounded-lg border border-white/10 bg-white/[0.03] px-4 py-2.5 hover:border-accent/20 transition-colors">
                <code class="text-accent font-mono text-sm">/add.new</code>
                <p class="text-muted text-xs mt-0.5">AI-guided feature discovery → <code class="text-foreground">about.md</code></p>
              </div>
              <div class="rounded-lg border border-white/10 bg-white/[0.03] px-4 py-2.5 hover:border-accent/20 transition-colors">
                <code class="text-accent font-mono text-sm">/add.init</code>
                <p class="text-muted text-xs mt-0.5">Project onboarding → <code class="text-foreground">owner.md</code></p>
              </div>
              <div class="rounded-lg border border-white/10 bg-white/[0.03] px-4 py-2.5 hover:border-accent/20 transition-colors">
                <code class="text-accent font-mono text-sm">/add.xray</code>
                <p class="text-muted text-xs mt-0.5">Map architecture, classify apps</p>
              </div>
            </div>
          </div>

          <!-- Planning -->
          <div class="rounded-xl border border-white/5 bg-white/[0.015] p-5">
            <h3 class="font-display font-bold text-xs tracking-widest uppercase text-foreground mb-4">Planning</h3>
            <div class="space-y-2.5">
              <div class="rounded-lg border border-white/10 bg-white/[0.03] px-4 py-2.5 hover:border-accent/20 transition-colors">
                <code class="text-accent font-mono text-sm">/add.design</code>
                <p class="text-muted text-xs mt-0.5">UX spec, mobile-first. Coordinates subagents</p>
              </div>
              <div class="rounded-lg border border-white/10 bg-white/[0.03] px-4 py-2.5 hover:border-accent/20 transition-colors">
                <code class="text-accent font-mono text-sm">/add.plan</code>
                <p class="text-muted text-xs mt-0.5">Technical planning → <code class="text-foreground">plan.md</code>. Epic vs Feature detection</p>
              </div>
            </div>
          </div>

          <!-- Implementation -->
          <div class="rounded-xl border border-white/5 bg-white/[0.015] p-5">
            <h3 class="font-display font-bold text-xs tracking-widest uppercase text-foreground mb-4">Implementation</h3>
            <div class="space-y-2.5">
              <div class="rounded-lg border border-white/10 bg-white/[0.03] px-4 py-2.5 hover:border-accent/20 transition-colors">
                <code class="text-accent font-mono text-sm">/add.build</code>
                <p class="text-muted text-xs mt-0.5">Subagent-driven implementation. Supports Epics</p>
              </div>
              <div class="rounded-lg border border-white/10 bg-white/[0.03] px-4 py-2.5 hover:border-accent/20 transition-colors">
                <code class="text-accent font-mono text-sm">/add.autopilot</code>
                <p class="text-muted text-xs mt-0.5">Full autonomous implementation, no interaction</p>
              </div>
            </div>
          </div>

          <!-- Quality -->
          <div class="rounded-xl border border-white/5 bg-white/[0.015] p-5">
            <h3 class="font-display font-bold text-xs tracking-widest uppercase text-foreground mb-4">Quality</h3>
            <div class="space-y-2.5">
              <div class="rounded-lg border border-white/10 bg-white/[0.03] px-4 py-2.5 hover:border-accent/20 transition-colors">
                <code class="text-accent font-mono text-sm">/add.check</code>
                <p class="text-muted text-xs mt-0.5">Code review + auto-correction</p>
              </div>
              <div class="rounded-lg border border-white/10 bg-white/[0.03] px-4 py-2.5 hover:border-accent/20 transition-colors">
                <code class="text-accent font-mono text-sm">/add.test</code>
                <p class="text-muted text-xs mt-0.5">Generate tests (80% coverage target)</p>
              </div>
              <div class="rounded-lg border border-white/10 bg-white/[0.03] px-4 py-2.5 hover:border-accent/20 transition-colors">
                <code class="text-accent font-mono text-sm">/add.audit</code>
                <p class="text-muted text-xs mt-0.5">Full project health analysis</p>
              </div>
            </div>
          </div>

          <!-- Delivery -->
          <div class="rounded-xl border border-white/5 bg-white/[0.015] p-5">
            <h3 class="font-display font-bold text-xs tracking-widest uppercase text-foreground mb-4">Delivery</h3>
            <div class="space-y-2.5">
              <div class="rounded-lg border border-white/10 bg-white/[0.03] px-4 py-2.5 hover:border-accent/20 transition-colors">
                <code class="text-accent font-mono text-sm">/add.ship</code>
                <p class="text-muted text-xs mt-0.5">Changelog, docs, finalize. Routes to PR or merge</p>
              </div>
              <div class="rounded-lg border border-white/10 bg-white/[0.03] px-4 py-2.5 hover:border-accent/20 transition-colors">
                <code class="text-accent font-mono text-sm">/add.pr</code>
                <p class="text-muted text-xs mt-0.5">Create PR for code review</p>
              </div>
              <div class="rounded-lg border border-white/10 bg-white/[0.03] px-4 py-2.5 hover:border-accent/20 transition-colors">
                <code class="text-accent font-mono text-sm" style="color:#ff4444">/add.hotfix</code>
                <p class="text-muted text-xs mt-0.5">Emergency fix with global ID (H[NNNN])</p>
              </div>
            </div>
          </div>

          <!-- Utility -->
          <div class="rounded-xl border border-white/5 bg-white/[0.015] p-5">
            <h3 class="font-display font-bold text-xs tracking-widest uppercase text-foreground mb-4">Utilities</h3>
            <div class="space-y-2.5">
              <div class="rounded-lg border border-white/10 bg-white/[0.03] px-4 py-2.5 hover:border-accent/20 transition-colors">
                <code class="text-accent font-mono text-sm">/add</code>
                <p class="text-muted text-xs mt-0.5">Smart gateway — answers questions, guides flow</p>
              </div>
              <div class="rounded-lg border border-white/10 bg-white/[0.03] px-4 py-2.5 hover:border-accent/20 transition-colors">
                <code class="text-accent font-mono text-sm">/add.copy</code>
                <p class="text-muted text-xs mt-0.5">SaaS copy generator</p>
              </div>
              <div class="rounded-lg border border-white/10 bg-white/[0.03] px-4 py-2.5 hover:border-accent/20 transition-colors">
                <code class="text-accent font-mono text-sm">/add.landing</code>
                <p class="text-muted text-xs mt-0.5">High-conversion SaaS landing page builder</p>
              </div>
              <div class="rounded-lg border border-white/10 bg-white/[0.03] px-4 py-2.5 hover:border-accent/20 transition-colors">
                <code class="text-accent font-mono text-sm">/add.ux</code>
                <p class="text-muted text-xs mt-0.5">Quick UX — loads ux-design for free context</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Divider -->
      <div class="border-t border-white/5 my-16"></div>

      <!-- FLOWS -->
      <section id="flows" class="mb-20">
        <p class="font-mono text-accent text-xs tracking-widest uppercase mb-4">Reference</p>
        <h2 class="font-display font-bold text-2xl sm:text-3xl mb-4">Flows</h2>
        <p class="text-muted-light mb-8">
          Pick the shortest path that fits. Less ceremony, same quality.
        </p>

        <!-- Flows HTML -->
        <div class="space-y-10">

          <!-- Complete -->
          <div>
            <h3 class="font-display font-bold text-sm tracking-widest uppercase mb-1">Complete Flow</h3>
            <p class="text-muted text-xs mb-4">Complex features with UI — full discovery, design, planning, implementation, review</p>
            <div class="flex flex-wrap items-center gap-2">
              <span class="flow-node">Brainstorm<br/><span class="flow-cmd">/add.brainstorm</span></span>
              <span class="flow-arrow">→</span>
              <span class="flow-node">New<br/><span class="flow-cmd">/add.new</span></span>
              <span class="flow-arrow">→</span>
              <span class="flow-node">Design<br/><span class="flow-cmd">/add.design</span></span>
              <span class="flow-arrow">→</span>
              <span class="flow-node">Plan<br/><span class="flow-cmd">/add.plan</span></span>
              <span class="flow-arrow">→</span>
              <span class="flow-node">Code<br/><span class="flow-cmd">/add.build</span></span>
              <span class="flow-arrow">→</span>
              <span class="flow-node">Check<br/><span class="flow-cmd">/add.check</span></span>
              <span class="flow-arrow">→</span>
              <span class="flow-node">Ship<br/><span class="flow-cmd">/add.ship</span></span>
            </div>
          </div>

          <!-- Standard -->
          <div>
            <h3 class="font-display font-bold text-sm tracking-widest uppercase mb-1">Standard Flow</h3>
            <p class="text-muted text-xs mb-4">Features without complex UI — skip brainstorm and design</p>
            <div class="flex flex-wrap items-center gap-2">
              <span class="flow-node">New<br/><span class="flow-cmd">/add.new</span></span>
              <span class="flow-arrow">→</span>
              <span class="flow-node">Plan<br/><span class="flow-cmd">/add.plan</span></span>
              <span class="flow-arrow">→</span>
              <span class="flow-node">Code<br/><span class="flow-cmd">/add.build</span></span>
              <span class="flow-arrow">→</span>
              <span class="flow-node">Ship<br/><span class="flow-cmd">/add.ship</span></span>
            </div>
          </div>

          <!-- Lean -->
          <div>
            <h3 class="font-display font-bold text-sm tracking-widest uppercase mb-1">Lean Flow</h3>
            <p class="text-muted text-xs mb-4">Small changes, quick tasks — minimal ceremony</p>
            <div class="flex flex-wrap items-center gap-2">
              <span class="flow-node">New<br/><span class="flow-cmd">/add.new</span></span>
              <span class="flow-arrow">→</span>
              <span class="flow-node">Code<br/><span class="flow-cmd">/add.build</span></span>
              <span class="flow-arrow">→</span>
              <span class="flow-node">Ship<br/><span class="flow-cmd">/add.ship</span></span>
            </div>
          </div>

          <!-- Autonomous -->
          <div>
            <h3 class="font-display font-bold text-sm tracking-widest uppercase mb-1" style="color:#ffaa00">Autonomous Flow</h3>
            <p class="text-muted text-xs mb-4">Full AI implementation, no human interaction needed</p>
            <div class="flex flex-wrap items-center gap-2">
              <span class="flow-node">New<br/><span class="flow-cmd">/add.new</span></span>
              <span class="flow-arrow" style="color:#ffaa00">→</span>
              <span class="flow-node" style="border-color:#ffaa00;background:rgba(255,170,0,0.05)">Autopilot<br/><span class="flow-cmd" style="color:#ffaa00">/add.autopilot</span></span>
              <span class="flow-arrow" style="color:#ffaa00">→</span>
              <span class="flow-node">Ship<br/><span class="flow-cmd">/add.ship</span></span>
            </div>
          </div>

          <!-- Emergency -->
          <div>
            <h3 class="font-display font-bold text-sm tracking-widest uppercase mb-1" style="color:#ff4444">Emergency Flow</h3>
            <p class="text-muted text-xs mb-4">Critical bug in production — fast track to fix</p>
            <div class="flex flex-wrap items-center gap-2">
              <span class="flow-node" style="border-color:#ff4444;background:rgba(255,68,68,0.05)">Hotfix<br/><span class="flow-cmd" style="color:#ff4444">/add.hotfix</span></span>
